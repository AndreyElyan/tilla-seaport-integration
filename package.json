{
  "name": "tilla-seaport-integration",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm -w apps/backend run start:dev",
    "dev:frontend": "npm -w apps/frontend run dev",
    "build": "npm -w apps/backend run build && npm -w apps/frontend run build",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "db:generate": "npm -w apps/backend run prisma:generate",
    "db:migrate": "npm -w apps/backend run prisma:migrate",
    "db:studio": "npm -w apps/backend run prisma:studio"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3"
  }
}
