generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Seaport {
  id Int @id @default(autoincrement())
  portName String
  locode String @unique
  latitude Float
  longitude Float
  timezoneOlson String?
  countryIso String?
  clientSource String @default("tilla")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("seaports")
}
